<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Uses Theme.MaterialComponents (AppCompat-based) because
        FragmentActivity + Material components both require AppCompat heritage.
    -->
    <style name="Theme.FlowLauncher" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorPrimaryVariant">#CCCCCC</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorAccent">#FFFFFF</item>
        <item name="colorSurface">#121212</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="alertDialogTheme">@style/Theme.FlowLauncher.Dialog</item>
    </style>

    <style name="Theme.FlowLauncher.Dialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:background">#1E1E1E</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="colorAccent">#FFFFFF</item>
    </style>

    <style name="Theme.FlowLauncher.Settings" parent="Theme.FlowLauncher">
        <item name="android:windowBackground">#000000</item>
    </style>

</resources>
