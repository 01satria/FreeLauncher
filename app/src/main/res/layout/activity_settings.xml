<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="24dp"
            android:layout_marginBottom="32dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:tint="#FFFFFF"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- ── APPEARANCE ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPEARANCE"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Theme"
                android:textColor="#FFFFFF" android:textSize="16sp" />
            <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spinnerTheme"
                android:layout_width="140dp" android:layout_height="wrap_content" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginVertical="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Text Alignment"
                android:textColor="#FFFFFF" android:textSize="16sp" />
            <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spinnerAlignment"
                android:layout_width="140dp" android:layout_height="wrap_content" />
        </LinearLayout>


        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginVertical="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Transparent Background"
                android:textColor="#FFFFFF" android:textSize="16sp" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchTransparentBg"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="#FFFFFF" android:trackTint="#55FFFFFF" />
        </LinearLayout>

        <!-- ── CLOCK ──────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CLOCK"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="24-Hour Format"
                android:textColor="#FFFFFF" android:textSize="16sp" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch24Hour"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="#FFFFFF" android:trackTint="#55FFFFFF" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginVertical="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Show Date"
                android:textColor="#FFFFFF" android:textSize="16sp" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchShowDate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="#FFFFFF" android:trackTint="#55FFFFFF" />
        </LinearLayout>

        <!-- ── HOME SCREEN ────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HOME SCREEN"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Max Apps on Home"
                android:textColor="#FFFFFF" android:textSize="16sp" />
            <NumberPicker android:id="@+id/npHomeApps"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ── SCREEN TIME ────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCREEN TIME"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Show Screen Time"
                android:textColor="#FFFFFF" android:textSize="16sp" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchScreenTime"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="#FFFFFF" android:trackTint="#55FFFFFF" />
        </LinearLayout>

        <Button
            android:id="@+id/btnGrantUsage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Grant Usage Access"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_outline"
            android:layout_marginTop="8dp" />

        <!-- ── WEATHER ───────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WEATHER"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvWeatherLocationStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#77FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSetWeatherLocation"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Set Weather Location"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_outline"
            android:layout_marginBottom="16dp" />

        <!-- ── APPS ───────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPS"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnManageHidden"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Manage Hidden Apps"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_outline"
            android:layout_marginBottom="48dp" />

    </LinearLayout>
</ScrollView>
