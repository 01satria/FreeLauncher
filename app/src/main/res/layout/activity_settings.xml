<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/settingsContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="64dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp"
            android:layout_marginTop="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_back"
                android:tint="#FFFFFF"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- ── APPEARANCE ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPEARANCE"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/cardAppearance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_feed_section"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Launcher Theme"
                    android:textColor="#FFFFFF" android:textSize="15sp" />
                <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spinnerTheme"
                    android:layout_width="150dp" android:layout_height="44dp"
                    android:backgroundTint="#44FFFFFF" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#15FFFFFF" android:layout_marginVertical="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Text Alignment"
                    android:textColor="#FFFFFF" android:textSize="15sp" />
                <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spinnerAlignment"
                    android:layout_width="150dp" android:layout_height="44dp"
                    android:backgroundTint="#44FFFFFF" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#15FFFFFF" android:layout_marginVertical="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Font Style"
                    android:textColor="#FFFFFF" android:textSize="15sp" />
                <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spinnerFont"
                    android:layout_width="150dp" android:layout_height="44dp"
                    android:backgroundTint="#44FFFFFF" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#15FFFFFF" android:layout_marginVertical="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Transparent UI"
                    android:textColor="#FFFFFF" android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchTransparentBg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="#FFFFFF" android:trackTint="#33FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── CLOCK & DATE ────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CLOCK &amp; DATE"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/cardClock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_feed_section"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="24-Hour Format"
                    android:textColor="#FFFFFF" android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch24Hour"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="#FFFFFF" android:trackTint="#33FFFFFF" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#15FFFFFF" android:layout_marginVertical="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Show Current Date"
                    android:textColor="#FFFFFF" android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchShowDate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="#FFFFFF" android:trackTint="#33FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── HOME SCREEN ────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HOME CONTENT"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/cardHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_feed_section"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Max Apps on Home"
                    android:textColor="#FFFFFF" android:textSize="15sp" />
                <NumberPicker android:id="@+id/npHomeApps"
                    android:layout_width="wrap_content" android:layout_height="72dp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#15FFFFFF" android:layout_marginVertical="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Enable Screen Time"
                    android:textColor="#FFFFFF" android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchScreenTime"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="#FFFFFF" android:trackTint="#33FFFFFF" />
            </LinearLayout>

            <Button
                android:id="@+id/btnGrantUsage"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Grant Usage Access"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:background="@drawable/bg_btn_outline"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- ── WEATHER ───────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WEATHER INFOS"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/cardWeather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_feed_section"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvWeatherLocationStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#77FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnSetWeatherLocation"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Auto-detect Location"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:background="@drawable/bg_btn_outline" />
        </LinearLayout>

        <!-- ── APPS MANAGEMENT ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPS MANAGEMENT"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/cardApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_feed_section"
            android:padding="20dp">

            <Button
                android:id="@+id/btnManageHidden"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Manage Hidden Apps"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:background="@drawable/bg_btn_outline" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
