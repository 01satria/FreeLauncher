<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homePageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/homeContentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="56dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false">

        <TextClock
            android:id="@+id/tvClock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:format12Hour="hh:mm"
            android:format24Hour="HH:mm"
            android:textColor="#FFFFFF"
            android:textSize="84sp"
            android:textStyle="bold"
            android:letterSpacing="-0.05"
            android:includeFontPadding="false" />

        <LinearLayout
            android:id="@+id/llDateWeather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="-6dp">

            <TextClock
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="EEE, d MMM"
                android:format24Hour="EEE, d MMM"
                android:textColor="#77FFFFFF"
                android:textSize="14sp"
                android:letterSpacing="0.01" />

            <LinearLayout
                android:id="@+id/llWeather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp"
                android:layout_marginStart="4dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivWeatherIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="5dp"
                    android:contentDescription="Weather" />

                <TextView
                    android:id="@+id/tvWeatherTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llNextEvent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:visibility="gone">

            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_nothing_pill" />

            <TextView
                android:id="@+id/tvNextEvent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvUsageToday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#44FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvScreenTimeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable screen time"
            android:textColor="#33FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHomeApps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:overScrollMode="never"
            android:clipToPadding="false" />

    </LinearLayout>

</RelativeLayout>
