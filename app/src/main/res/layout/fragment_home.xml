<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homePageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Main content fills screen, bottom padding for action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="96dp">

        <!-- Clock -->
        <TextClock
            android:id="@+id/tvClock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:format12Hour="hh:mm"
            android:format24Hour="HH:mm"
            android:textColor="#FFFFFF"
            android:textSize="76sp"
            android:textStyle="bold"
            android:letterSpacing="-0.04"
            android:includeFontPadding="false" />

        <!-- Date -->
        <TextClock
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:format12Hour="EEEE, d MMM"
            android:format24Hour="EEEE, d MMM"
            android:textColor="#77FFFFFF"
            android:textSize="15sp"
            android:layout_marginTop="2dp" />

        <!-- Next event chip -->
        <TextView
            android:id="@+id/tvNextEvent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:textColor="#DDFFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:background="@drawable/bg_chip"
            android:visibility="gone" />

        <!-- Screen time total -->
        <TextView
            android:id="@+id/tvUsageToday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#55FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <!-- Screen time permission hint -->
        <TextView
            android:id="@+id/tvScreenTimeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to enable screen time →"
            android:textColor="#44FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <!-- Push apps to bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Favourite apps list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHomeApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- ── Bottom action bar ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="28dp"
        android:paddingTop="12dp">

        <ImageButton
            android:id="@+id/btnDrawer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_swipe_up"
            android:tint="#88FFFFFF"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Open App Drawer" />

    </LinearLayout>

</RelativeLayout>
