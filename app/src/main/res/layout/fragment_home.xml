<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homePageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/homeContentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="96dp"
        android:clipToPadding="false">

        <!-- Clock -->
        <TextClock
            android:id="@+id/tvClock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:format12Hour="hh:mm"
            android:format24Hour="HH:mm"
            android:textColor="#FFFFFF"
            android:textSize="76sp"
            android:textStyle="bold"
            android:letterSpacing="-0.04"
            android:includeFontPadding="false" />

        <!-- Date + Weather row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextClock
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="EEEE, d MMM"
                android:format24Hour="EEEE, d MMM"
                android:textColor="#77FFFFFF"
                android:textSize="15sp" />

            <!-- Weather icon + temp (click to refresh) -->
            <LinearLayout
                android:id="@+id/llWeather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="4dp"
                android:visibility="gone">
                
                <ImageView
                    android:id="@+id/ivWeatherIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="6dp"
                    android:tint="#AAFFFFFF" />
                    
                <TextView
                    android:id="@+id/tvWeatherTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Next event chip -->
        <TextView
            android:id="@+id/tvNextEvent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:textColor="#DDFFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:background="@drawable/bg_chip"
            android:visibility="gone" />

        <!-- Screen time total -->
        <TextView
            android:id="@+id/tvUsageToday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#55FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <!-- Screen time permission hint -->
        <TextView
            android:id="@+id/tvScreenTimeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to enable screen time →"
            android:textColor="#44FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHomeApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:clipToPadding="false" />

    </LinearLayout>

</RelativeLayout>
