<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homePageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="60dp"
    android:paddingBottom="32dp"
    android:background="@android:color/transparent">

    <!-- Top row: Settings + Focus -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginBottom="8dp">

        <ImageButton
            android:id="@+id/btnFocus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_focus"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#AAFFFFFF"
            android:contentDescription="Focus Mode"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#AAFFFFFF"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Clock -->
    <TextClock
        android:id="@+id/tvClock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:format12Hour="hh:mm"
        android:format24Hour="HH:mm"
        android:textColor="#FFFFFF"
        android:textSize="80sp"
        android:textStyle="bold"
        android:letterSpacing="-0.05"
        android:includeFontPadding="false" />

    <!-- Date -->
    <TextClock
        android:id="@+id/tvDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:format12Hour="EEEE, MMMM d"
        android:format24Hour="EEEE, MMMM d"
        android:textColor="#AAFFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp" />

    <!-- Screen time total -->
    <TextView
        android:id="@+id/tvUsageToday"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#77FFFFFF"
        android:textSize="13sp"
        android:layout_marginBottom="32dp"
        android:visibility="gone" />

    <!-- Screen-time permission hint -->
    <TextView
        android:id="@+id/tvScreenTimeHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to enable screen time →"
        android:textColor="#55FFFFFF"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <!-- Favourite apps list — takes remaining space -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHomeApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:clipToPadding="false" />

    <!-- Swipe left hint at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <!-- Swipe-up for apps -->
        <ImageView
            android:id="@+id/ivSwipeHint"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_swipe_up"
            android:tint="#44FFFFFF"
            android:contentDescription="Swipe up for apps" />

    </LinearLayout>

</LinearLayout>
