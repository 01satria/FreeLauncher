<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Dim overlay when drawer opens -->
    <View
        android:id="@+id/drawerDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:alpha="0"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- App Drawer — Nothing style bottom sheet -->
    <LinearLayout
        android:id="@+id/drawerSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_nothing_drawer"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        app:behavior_skipCollapsed="true">

        <!-- Drag handle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <View
                android:id="@+id/drawerHandleBar"
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:background="@drawable/bg_nothing_handle" />
        </LinearLayout>

        <!-- Drawer header: Apps title + settings -->
        <LinearLayout
            android:id="@+id/drawerHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvAppsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Apps"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03" />

            <ImageButton
                android:id="@+id/btnDrawerSettings"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_settings"
                android:tint="#55FFFFFF"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- Search bar — Nothing minimal style -->
        <LinearLayout
            android:id="@+id/drawerSearchContainer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_nothing_search"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:id="@+id/ivSearchIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:tint="#44FFFFFF"
                android:layout_marginEnd="10dp"
                android:contentDescription="Search" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search"
                android:textColorHint="#33FFFFFF"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:letterSpacing="-0.01"
                android:background="@null"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionDone|flagNoFullscreen"
                android:singleLine="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />
        </LinearLayout>

        <!-- App list + Fast Scroll -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:layout_height="0dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDrawerApps"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="32dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none" />

            <!-- Fast scroller container -->
            <LinearLayout
                android:id="@+id/drawerScrollerContainer"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:gravity="center_vertical|end">

                <TextView
                    android:id="@+id/tvScrollerPopup"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_nothing_pill"
                    android:backgroundTint="#44FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:text="A"
                    android:visibility="gone"
                    android:layout_marginEnd="12dp" />

                <View
                    android:id="@+id/drawerScrollerThumb"
                    android:layout_width="4dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_nothing_pill"
                    android:backgroundTint="#22FFFFFF" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
