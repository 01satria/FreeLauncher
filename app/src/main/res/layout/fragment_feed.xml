<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/feedRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="48dp">

        <!-- ── HEADER row: title + settings ──────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/tvFeedTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Feeds"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnFeedSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:tint="#88FFFFFF"
                android:background="@drawable/bg_chip"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- ── MY EVENTS CARD ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:padding="16dp">

            <!-- Collapsible header -->
            <LinearLayout
                android:id="@+id/layoutEventsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Events"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEventsChevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▲"
                    android:textColor="#77FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Collapsible content -->
            <LinearLayout
                android:id="@+id/layoutEventsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <!-- Calendar permission card -->
                <LinearLayout
                    android:id="@+id/layoutCalendarPermission"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Calendar Access Needed"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Allow access to show your events with countdown timers."
                        android:textColor="#77FFFFFF"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnGrantCalendar"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Grant Calendar Access"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@drawable/bg_btn_outline" />
                </LinearLayout>

                <!-- No events message -->
                <TextView
                    android:id="@+id/tvEventsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No upcoming events in next 30 days."
                    android:textColor="#44FFFFFF"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- Events RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEvents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── TASKS CARD ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp">

            <!-- Tasks widget -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Today"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnAddTodo"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_add"
                        android:tint="#AAFFFFFF"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Add task" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTasksEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No tasks yet."
                    android:textColor="#44FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTodos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
 />
            </LinearLayout>
        </LinearLayout>

        <!-- ── SCREEN TIME CARD ────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/cardScreenTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:visibility="gone">

            <!-- Total + label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvScreenTimeTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SCREEN TIME"
                        android:textColor="#55FFFFFF"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvScreenTimeDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#55FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Top apps row -->
            <LinearLayout
                android:id="@+id/layoutTopApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </LinearLayout>

        <!-- Hint: screen time permission -->
        <TextView
            android:id="@+id/tvFeedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:textColor="#33FFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
