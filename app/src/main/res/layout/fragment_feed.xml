<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/feedRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingBottom="64dp"
        android:paddingHorizontal="20dp">

        <!-- ── PAGE HEADER ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvFeedTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Feed"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:textColor="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnFeedSettings"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_settings"
                android:tint="#55FFFFFF"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- ── EVENTS SECTION ──────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/sectionEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_feed_section"
            android:padding="18dp">

            <!-- Section header row -->
            <LinearLayout
                android:id="@+id/layoutEventsHeader"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Calendar"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    android:textColor="#66FFFFFF"
                    android:id="@+id/tvEventsLabel" />

                <TextView
                    android:id="@+id/tvEventsChevron"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:text="▾"
                    android:textColor="#44FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Pinned events strip — visible ONLY when collapsed -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPinnedEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:visibility="gone" />

            <!-- Collapsible body -->
            <LinearLayout
                android:id="@+id/layoutEventsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Calendar permission -->
                <LinearLayout
                    android:id="@+id/layoutCalendarPermission"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No calendar access"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Grant access to see your events here."
                        android:textColor="#55FFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="14dp"
                        android:lineSpacingMultiplier="1.4" />

                    <Button
                        android:id="@+id/btnGrantCalendar"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:text="Grant Access"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@drawable/bg_btn_outline" />
                </LinearLayout>

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:id="@+id/containerEventSearch"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_search"
                        android:layout_marginEnd="8dp"
                        android:alpha="0.4"
                        android:contentDescription="Search" />

                    <EditText
                        android:id="@+id/etEventSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Search events…"
                        android:textColorHint="#33FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:background="@null"
                        android:inputType="text"
                        android:maxLines="1"
                        android:imeOptions="actionSearch|flagNoFullscreen"
                        android:singleLine="true" />

                    <ImageButton
                        android:id="@+id/btnClearEventSearch"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_close_small"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Clear"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Divider below search -->
                <View
                    android:id="@+id/dividerEventSearch"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/bg_divider"
                    android:layout_marginBottom="10dp" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tvEventsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No upcoming events."
                    android:textColor="#33FFFFFF"
                    android:textSize="13sp"
                    android:paddingVertical="4dp"
                    android:visibility="gone" />

                <!-- Events list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEvents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>

        <!-- ── TASKS SECTION ───────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/sectionTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_feed_section"
            android:padding="18dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTasksLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tasks"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    android:textColor="#66FFFFFF" />

                <ImageButton
                    android:id="@+id/btnAddTodo"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add"
                    android:tint="#44FFFFFF"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Add task" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTasksEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nothing here yet."
                android:textColor="#33FFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTodos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never" />

        </LinearLayout>

        <!-- ── SCREEN TIME SECTION ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/cardScreenTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_feed_section"
            android:padding="18dp"
            android:visibility="gone">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvScreenTimeLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Screen Time"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    android:textColor="#66FFFFFF" />

                <TextView
                    android:id="@+id/tvScreenTimeTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Top apps bar list -->
            <LinearLayout
                android:id="@+id/layoutTopApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
