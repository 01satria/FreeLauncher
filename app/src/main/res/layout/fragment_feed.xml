<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/feedRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/feedContentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingBottom="64dp"
        android:paddingHorizontal="20dp">

<!-- github.com/01satria -->

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:id="@+id/tvFeedTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Feed"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:textColor="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnFeedSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_settings"
                android:tint="#44FFFFFF"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- EVENTS SECTION -->
        <LinearLayout
            android:id="@+id/sectionEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_nothing_card"
            android:padding="18dp">

            <!-- Header row -->
            <LinearLayout
                android:id="@+id/layoutEventsHeader"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless">

                <TextView
                    android:id="@+id/tvEventsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CALENDAR"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textColor="#44FFFFFF" />

                <TextView
                    android:id="@+id/tvEventsChevron"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:text="▾"
                    android:textColor="#33FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Pinned events (collapsed state) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPinnedEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:visibility="gone" />

            <!-- Expanded content -->
            <LinearLayout
                android:id="@+id/layoutEventsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Calendar permission -->
                <LinearLayout
                    android:id="@+id/layoutCalendarPermission"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No calendar access"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Grant access to see your events."
                        android:textColor="#55FFFFFF"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnGrantCalendar"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="Grant Access"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/bg_nothing_chip" />
                </LinearLayout>

                <!-- Search bar -->
                <LinearLayout
                    android:id="@+id/containerEventSearch"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_search"
                        android:layout_marginEnd="8dp"
                        android:alpha="0.3"
                        android:contentDescription="Search" />

                    <EditText
                        android:id="@+id/etEventSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Search events…"
                        android:textColorHint="#33FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@null"
                        android:inputType="text"
                        android:maxLines="1"
                        android:imeOptions="actionSearch|flagNoFullscreen"
                        android:singleLine="true" />

                    <ImageButton
                        android:id="@+id/btnClearEventSearch"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_close_small"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Clear"
                        android:visibility="gone" />
                </LinearLayout>

                <View
                    android:id="@+id/dividerEventSearch"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0FFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvEventsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No upcoming events."
                    android:textColor="#33FFFFFF"
                    android:textSize="12sp"
                    android:paddingVertical="4dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEvents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>

        <!-- TASKS SECTION -->
        <LinearLayout
            android:id="@+id/sectionTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_nothing_card"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTasksLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TASKS"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textColor="#44FFFFFF" />

                <ImageButton
                    android:id="@+id/btnAddTodo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_add"
                    android:tint="#44FFFFFF"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Add task" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTasksEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nothing here yet."
                android:textColor="#33FFFFFF"
                android:textSize="12sp"
                android:paddingBottom="4dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTodos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never" />

        </LinearLayout>

        <!-- SCREEN TIME SECTION -->
        <LinearLayout
            android:id="@+id/cardScreenTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_nothing_card"
            android:padding="18dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvScreenTimeLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SCREEN TIME"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textColor="#44FFFFFF" />

                <TextView
                    android:id="@+id/tvScreenTimeTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- No permission state -->
            <LinearLayout
                android:id="@+id/layoutScreenTimePermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable Usage Access to see screen time stats."
                    android:textColor="#77FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnGrantUsageAccess"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Enable"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:paddingHorizontal="16dp"
                    style="?attr/materialButtonStyle" />

            </LinearLayout>

            <!-- Top 3 apps chips -->
            <LinearLayout
                android:id="@+id/layoutTopApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:weightSum="3">

                <include layout="@layout/item_screentime_chip"
                    android:id="@+id/chipApp1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <Space android:layout_width="8dp" android:layout_height="1dp" />

                <include layout="@layout/item_screentime_chip"
                    android:id="@+id/chipApp2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <Space android:layout_width="8dp" android:layout_height="1dp" />

                <include layout="@layout/item_screentime_chip"
                    android:id="@+id/chipApp3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
