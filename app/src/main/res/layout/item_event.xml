<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="9dp"
    android:baselineAligned="false">

    <!-- Left color accent bar -->
    <View
        android:id="@+id/viewEventAccent"
        android:layout_width="3dp"
        android:layout_height="36dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_event_accent" />

    <!-- Title + date -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#F2F2F2" />

        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:textColor="#77FFFFFF" />
    </LinearLayout>

    <!-- Countdown pill -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="9dp"
        android:paddingVertical="4dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_countdown_pill" />

    <!-- Pin button — visible only during search -->
    <ImageButton
        android:id="@+id/btnPinEvent"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_pin_outline"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Pin event"
        android:visibility="gone" />

</LinearLayout>
